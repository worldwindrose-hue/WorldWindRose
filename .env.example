# ROSA OS — Environment Configuration
# Copy this to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────

# OpenRouter API key (get at https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-...

# ── Model selection ───────────────────────────────────────────────────────────

# Primary cloud model (Rosa's brain)
CLOUD_MODEL=moonshotai/kimi-k2.5

# Fallback model if Kimi is unavailable
CLOUD_FALLBACK_MODEL=anthropic/claude-3.5-sonnet

# Local model (Ollama) for private/offline tasks
LOCAL_MODEL=llama3.2

# ── Endpoints ─────────────────────────────────────────────────────────────────

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434

# ── ROSA Core server ──────────────────────────────────────────────────────────

HOST=127.0.0.1
PORT=8000

# ── Memory ────────────────────────────────────────────────────────────────────

DB_PATH=memory/rosa.db

# ── Security ──────────────────────────────────────────────────────────────────

# Ask for human confirmation before executing commands
REQUIRE_CONFIRMATION=true

# Allow Rosa to perform file write operations (off by default)
ALLOW_FILE_OPERATIONS=false

# ── Self-improvement ──────────────────────────────────────────────────────────

SELF_IMPROVEMENT_ENABLED=true
SELF_IMPROVEMENT_LOOKBACK=50
SELF_IMPROVEMENT_MIN_FAILURES=3

# ── Debug ─────────────────────────────────────────────────────────────────────

DEBUG=false
